{
  "name": "unittcms-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node --env-file=.env index",
    "dev": "node index",
    "build": "tsoa spec-and-routes && tsc",
    "dev:ts": "npm run build && node dist/index.js",
    "migrate": "sequelize db:migrate",
    "seed": "sequelize db:seed:all",
    "drop": "sequelize db:migrate:undo:all"
  },
  "engines": {
    "node": ">=20.11.0"
  },
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.1",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "papaparse": "^5.5.2",
    "sequelize": "^6.37.7",
    "sequelize-cli": "^6.6.3",
    "sqlite3": "^5.1.7",
    "tsoa": "^6.6.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "xmlbuilder2": "^3.1.1"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.11.0",
    "@types/papaparse": "^5.3.14",
    "typescript": "^5.9.3"
  }
}